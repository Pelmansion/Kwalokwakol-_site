# Copier ce fichier en .env et remplir avec vos identifiants Gmail.
# Utilisez un mot de passe d'application (pas votre mot de passe Google) :
# https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=votre.adresse@gmail.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application_16_caracteres

# GeniusPay (paiement en ligne Wave, Orange, MTN, cartes…)
# Clés : https://pay.genius.ci/dashboard/settings?tab=api
# Important : .env n’est pas déployé sur Render/Git. Sur Render → Environment →
# les mêmes noms de variables, puis redeploy.
#
# TEST (écran « MODE TEST », références SANDBOX_…) :
#   GENIUS_API_KEY=pk_sandbox_…   GENIUS_API_SECRET=sk_sandbox_…   webhook whsec_sandbox_…
# PRODUCTION (vrais paiements) :
#   GENIUS_API_KEY=pk_live_…     GENIUS_API_SECRET=sk_live_…       webhook whsec_live_…
GENIUS_API_KEY=pk_sandbox_xxxxxxxx
GENIUS_API_SECRET=sk_sandbox_xxxxxxxx
# Secret affiché une seule fois à la création du webhook (sandbox ou live)
# GENIUS_WEBHOOK_SECRET=whsec_xxxxxxxx
# GENIUS_DEFAULT_COUNTRY=CI
